# ─── SERVER ───────────────────────────────────────
PORT=3000

# ─── SUPABASE (get from supabase.com > project > settings > database) ──
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── JWT ──────────────────────────────────────────
# Generate a strong random string - run this in terminal:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OTP (for now we use fake OTP - replace with Twilio later) ──────────
OTP_SECRET=otp_secret_key_here
# TWILIO_ACCOUNT_SID=your_twilio_sid       ← add later
# TWILIO_AUTH_TOKEN=your_twilio_token      ← add later
# TWILIO_PHONE_NUMBER=+1234567890          ← add later

# ─── CLIENT ───────────────────────────────────────
CLIENT_URL=http://localhost:8081
